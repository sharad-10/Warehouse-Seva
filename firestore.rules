rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function warehouseDoc(warehouseId) {
      return get(/databases/$(database)/documents/warehouses/$(warehouseId));
    }

    function isOwner(warehouseId) {
      return signedIn() &&
        warehouseDoc(warehouseId).data.ownerId == request.auth.uid;
    }

    function isMember(warehouseId) {
      return signedIn() &&
        exists(/databases/$(database)/documents/warehouseMembers/$(warehouseId + "_" + request.auth.uid));
    }

    function canAccessWarehouse(warehouseId) {
      return isOwner(warehouseId) || isMember(warehouseId);
    }

    function validWarehouseIdOnCreate() {
      return request.resource.data.warehouseId is string;
    }

    function ownerCanCreateInWarehouse() {
      return signedIn() &&
        validWarehouseIdOnCreate() &&
        isOwner(request.resource.data.warehouseId);
    }

    function ownerCanEditWarehouseResource() {
      return signedIn() &&
        resource.data.warehouseId is string &&
        isOwner(resource.data.warehouseId);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && request.auth.uid == userId;
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email is string;
      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /warehouses/{warehouseId} {
      allow read: if signedIn() &&
        (
          resource.data.ownerId == request.auth.uid ||
          isMember(warehouseId)
        );
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /sticks/{stickId} {
      allow read: if signedIn() &&
        resource.data.warehouseId is string &&
        canAccessWarehouse(resource.data.warehouseId);
      allow create: if ownerCanCreateInWarehouse();
      allow update, delete: if ownerCanEditWarehouseResource();
    }

    match /racks/{rackId} {
      allow read: if signedIn() &&
        resource.data.warehouseId is string &&
        canAccessWarehouse(resource.data.warehouseId);
      allow create: if ownerCanCreateInWarehouse();
      allow update, delete: if ownerCanEditWarehouseResource();
    }

    match /warehouseMembers/{memberId} {
      allow read: if signedIn();
      allow create: if ownerCanCreateInWarehouse();
      allow update, delete: if ownerCanEditWarehouseResource();
    }
  }
}
